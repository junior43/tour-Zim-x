
services:
  - type: web
    name: tour-zim-x
    env: python
    plan: free
    buildCommand: pip install -r requirements.txt
    startCommand: gunicorn app:app
    envVars:
      - key: OPENAI_API_KEY
        sync: false
      - key: ZAPIER_WEBHOOK_URL
        sync: false
      - key: OPENAI_MODEL
        value: gpt-4o-mini
